{
  "Environment": "qa",
  "Browser": {
    "Name": "chromium",
    "Headless": true,
    "Viewport": { "Width": 1440, "Height": 900 },
    "Video": "retain-on-failure",
    "Trace": "retain-on-failure",
    "Screenshot": "only-on-failure"
  },
  "Timeouts": {
    "DefaultMs": 30000,
    "NavigationMs": 60000,
    "ExpectMs": 10000
  },
  "Paths": {
    "ArtifactsRoot": "TestResults",
    "AuthStateDir": ".auth",
    "TraceDir": "TestResults/traces",
    "VideoDir": "TestResults/videos",
    "ScreenshotDir": "TestResults/screenshots"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "TestResults/logs/test-.log",
          "rollingInterval": "Day",
          "shared": true,
          "outputTemplate": "[{Timestamp:HH:mm:ss.fff} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
